# dependencies
collector/node_modules/
node_modules/

# scraper artifacts
collector/cache/
collector/logs/
collector/.profile/

# enumeration intermediates (URLは data/disc-urls.json に集約済み)
data/url-batches/

# translation intermediates (訳文は data/questions.json に集約)
data/ja-input/
data/ja-output/

# explanation intermediates (解説は data/questions.json に集約)
data/expl-input/
data/expl-output/
data/expl/

# 他試験(例: SAP)の中間物（成果は data/<exam>/questions.json に集約）
data/*/url-batches/
data/*/ja-input/
data/*/ja-output/
data/*/expl-input/
data/*/expl-output/

# build
app/dist/
